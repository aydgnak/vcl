{
  "name": "vcl",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "Vehicle Cost Ledger",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --workspaces build",
    "lint:root": "eslint . --cache",
    "lint:root:fix": "eslint . --cache --fix",
    "lint": "bun run lint:root && bun run --workspaces lint",
    "lint:fix": "bun run lint:root:fix && bun run --workspaces lint:fix",
    "typecheck": "bun run --workspaces typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "eslint": "10.5.0"
  }
}
