{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    ":semanticCommitTypeAll(chore)",
    ":widenPeerDependencies",
    ":approveMajorUpdates"
  ],
  "toolSettings": {
    "nodeMaxMemory": 4096
  },
  "rangeStrategy": "bump",
  "npm": {
    "commitMessageTopic": "{{prettyDepType}} {{depName}}"
  },
  "ignorePaths": [
    ".agents/**"
  ]
}
